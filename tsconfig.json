{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["es2022", "dom"],
    "declaration": true,
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "angularCompilerOptions": {
    "compilationMode": "partial",
    "strictTemplates": true,
    "strictInjectionParameters": true
  }
}
