{
  "name": "@slashand/sdui-blade-angular",
  "version": "1.0.4",
  "description": "Angular v21 SDUI rendering wrapper for the Agnostic Blade System.",
  "author": "Slashand Studio",
  "license": "MIT",
  "keywords": [
    "sdui",
    "server-driven-ui",
    "angular",
    "blade-system",
    "json-ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/slashand/sdui-blade-angular.git"
  },
  "bugs": {
    "url": "https://github.com/slashand/sdui-blade-angular/issues"
  },
  "homepage": "https://github.com/slashand/sdui-blade-angular#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "test": "vitest run",
    "publish:alpha": "npm version prerelease --preid=alpha --no-git-tag-version && npm run build && npm publish ./dist/sdui-blade-angular --tag alpha",
    "publish:prod": "npm version patch --no-git-tag-version && npm run build && npm publish ./dist/sdui-blade-angular"
  },
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@ngneat/elf": "latest",
    "@slashand/sdui-blade-core": "^1.0.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "jsdom": "^29.0.1",
    "ng-packagr": "^21.2.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zone.js": "^0.16.1"
  }
}
